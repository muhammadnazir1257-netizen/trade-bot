# Copy this file to `.env` and fill in real values.
# Never commit `.env` — only `.env.example`.

# --- Alpaca (paper trading by default) ---
APCA_API_KEY_ID=your_paper_key_id
APCA_API_SECRET_KEY=your_paper_secret_key
APCA_BASE_URL=https://paper-api.alpaca.markets

# Market-data API (default works for most accounts; IEX feed is free).
APCA_DATA_URL=https://data.alpaca.markets
ALPACA_DATA_FEED=iex

# Optional: HTTP timeout (seconds) for all Alpaca calls.
ALPACA_HTTP_TIMEOUT=30

# --- SendGrid (end-of-day email digest) ---
SENDGRID_API_KEY=your_sendgrid_key
NOTIFY_EMAIL=your@email.com
# Optional: separate verified sender; defaults to NOTIFY_EMAIL.
SENDGRID_FROM_EMAIL=
